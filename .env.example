# ============================================================
# FitWork Frontend - Environment Template
# Salin file ini menjadi .env dan isi sesuai environment Anda
# cp .env.example .env
# ============================================================

# ── App ──────────────────────────────────────────────────────
VITE_APP_NAME=FitWork
VITE_APP_ENV=development
VITE_APP_DEBUG=true
VITE_APP_VERSION=1.0.0

# ── Backend API ───────────────────────────────────────────────
VITE_API_URL=http://localhost/api
VITE_API_TIMEOUT=30000

# ── Auth ──────────────────────────────────────────────────────
VITE_JWT_EXPIRE=86400

# ── Pusher / Real-time ────────────────────────────────────────
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=ap1
VITE_PUSHER_HOST=
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https

# ── Midtrans (Payment Gateway) ────────────────────────────────
VITE_MIDTRANS_CLIENT_KEY=
VITE_MIDTRANS_IS_PRODUCTION=false
VITE_MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# ── AI / Health Monitoring ────────────────────────────────────
VITE_SENSOR_UPDATE_INTERVAL=1000
VITE_BREAK_DURATION=300
VITE_PERCLOS_THRESHOLD=0.40

# ── Map / Location ────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=

# ── Feature Flags ─────────────────────────────────────────────
VITE_ENABLE_EYE_TRACKING=true
VITE_ENABLE_GESTURE=true
VITE_ENABLE_RPPG=true
VITE_ENABLE_AI_INSIGHTS=true
